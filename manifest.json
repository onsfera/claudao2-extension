      "use_dynamic_url": false
   }, {
      "matches": [ "https://*.claude.ai/*", "https://claude.ai/*" ],
      "resources": [ "assets/onboarding-prompts-CWLEgoC0.js", "assets/content-script.ts-zjy42LA0.js" ],
      "use_dynamic_url": false
   }, {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "assets/accessibility-tree.js-DFF5rNzt.js", "assets/agent-visual-indicator.js-CW8zgsee.js" ],
      "use_dynamic_url": false
   } ]
}
