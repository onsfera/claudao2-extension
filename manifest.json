{
   "action": {
      "default_title": "Claudão²",
      "default_popup": "popup/popup.html"
   },
   "background": {
      "service_worker": "service-worker-loader.js",
      "type": "module"
   },
   "commands": {
      "toggle-side-panel": {
         "description": "Toggle Claude side panel",
         "suggested_key": {
            "default": "Ctrl+E",
            "mac": "Command+E"
         }
      }
   },
   "content_scripts": [ {
      "js": [ "memory/core.js", "memory/icons.js", "memory/inject.js" ],
      "matches": [ "https://claude.ai/*", "https://*.claude.ai/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "memory/bridge-capture.js" ],
      "matches": [ "<all_urls>" ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
   }, {
      "js": [ "assets/content-script.ts-loader-DKJzsl7H.js" ],
      "matches": [ "https://claude.ai/*", "https://*.claude.ai/*" ],
      "run_at": "document_end"
   }, {
      "all_frames": true,
      "js": [ "assets/accessibility-tree.js-DFF5rNzt.js" ],
      "matches": [ "\u003Call_urls>" ],
      "run_at": "document_start"
   }, {
      "all_frames": false,
      "js": [ "assets/agent-visual-indicator.js-CW8zgsee.js" ],
      "matches": [ "\u003Call_urls>" ],
      "run_at": "document_idle"
   } ],
   "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://api.anthropic.com wss://api.anthropic.com https://raw.githubusercontent.com https://claude.ai https://platform.claude.com https://api.segment.io https://*.segment.com https://*.ingest.us.sentry.io https://api.honeycomb.io https://browser-intake-us5-datadoghq.com wss://bridge.claudeusercontent.com wss://bridge-staging.claudeusercontent.com ws://127.0.0.1:* ws://localhost:* http://127.0.0.1:* http://localhost:*; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:;"
   },
   "description": "Claude in Chrome + memória persistente local (fork)",
   "externally_connectable": {
      "matches": [ "https://claude.ai/*", "https://*.claude.ai/*" ]
   },
   "host_permissions": [ "\u003Call_urls>" ],
   "icons": {
      "128": "icon-128.png"
   },
   "key": "",
   "manifest_version": 3,
   "minimum_chrome_version": "116",
   "name": "Claudão²",
   "options_page": "options.html",
   "permissions": [ "sidePanel", "storage", "activeTab", "scripting", "debugger", "tabGroups", "tabs", "alarms", "notifications", "webNavigation", "declarativeNetRequestWithHostAccess", "offscreen", "nativeMessaging", "unlimitedStorage", "downloads", "identity" ],
   "storage": {
      "managed_schema": "managed_schema.json"
   },
   "version": "1.1.0",
   "web_accessible_resources": [ {
      "matches": [ "https://*.claude.ai/*", "https://claude.ai/*" ],
